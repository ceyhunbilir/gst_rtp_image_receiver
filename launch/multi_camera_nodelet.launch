          args="load rtp_image_receiver/RtpReceiverNodelet /$(arg manager_name)" output="screen">
      <param name="udp_port" value="5013"/>
      <param name="width" value="$(eval 1920 if arg('camera_type') == 'C1' else 2880)"/>
      <param name="height" value="$(eval 1280 if arg('camera_type') == 'C1' else 1860)"/>
