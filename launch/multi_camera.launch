    <arg name="frame_id" value="camera8"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 9 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera9)">
    <arg name="namespace" value="camera9"/>
    <arg name="udp_port" value="5012"/>
    <arg name="frame_id" value="camera9"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

