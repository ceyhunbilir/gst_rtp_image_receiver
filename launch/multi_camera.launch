  </include>

  <!-- Camera 13 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera13)">
    <arg name="namespace" value="camera13"/>
    <arg name="udp_port" value="5016"/>
    <arg name="frame_id" value="camera13"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 14 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera14)">
    <arg name="namespace" value="camera14"/>
    <arg name="udp_port" value="5017"/>
    <arg name="frame_id" value="camera14"/>
    <arg name="width" value="1920"/>
