<?xml version="1.0"?>
<launch>
  <!-- Multi-camera launch file for up to 16 RTP image receivers -->

  <!-- Enable/Disable arguments for each camera -->
  <arg name="enable_camera1"  default="true"  doc="Enable camera 1"/>
  <arg name="enable_camera2"  default="true"  doc="Enable camera 2"/>
  <arg name="enable_camera3"  default="true"  doc="Enable camera 3"/>
  <arg name="enable_camera4"  default="true"  doc="Enable camera 4"/>
  <arg name="enable_camera5"  default="false" doc="Enable camera 5"/>
  <arg name="enable_camera6"  default="false" doc="Enable camera 6"/>
  <arg name="enable_camera7"  default="false" doc="Enable camera 7"/>
  <arg name="enable_camera8"  default="false" doc="Enable camera 8"/>
  <arg name="enable_camera9"  default="false" doc="Enable camera 9"/>
  <arg name="enable_camera10" default="false" doc="Enable camera 10"/>
  <arg name="enable_camera11" default="false" doc="Enable camera 11"/>
  <arg name="enable_camera12" default="false" doc="Enable camera 12"/>
  <arg name="enable_camera13" default="false" doc="Enable camera 13"/>
  <arg name="enable_camera14" default="false" doc="Enable camera 14"/>
  <arg name="enable_camera15" default="false" doc="Enable camera 15"/>
  <arg name="enable_camera16" default="false" doc="Enable camera 16"/>

  <!-- Camera 1 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera1)">
    <arg name="namespace" value="camera1"/>
    <arg name="udp_port" value="5004"/>
    <arg name="frame_id" value="camera1"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 2 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera2)">
    <arg name="namespace" value="camera2"/>
    <arg name="udp_port" value="5005"/>
    <arg name="frame_id" value="camera2"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 3 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera3)">
    <arg name="namespace" value="camera3"/>
    <arg name="udp_port" value="5006"/>
    <arg name="frame_id" value="camera3"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 4 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera4)">
    <arg name="namespace" value="camera4"/>
    <arg name="udp_port" value="5007"/>
    <arg name="frame_id" value="camera4"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 5 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera5)">
    <arg name="namespace" value="camera5"/>
    <arg name="udp_port" value="5008"/>
    <arg name="frame_id" value="camera5"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 6 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera6)">
    <arg name="namespace" value="camera6"/>
    <arg name="udp_port" value="5009"/>
    <arg name="frame_id" value="camera6"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 7 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera7)">
    <arg name="namespace" value="camera7"/>
    <arg name="udp_port" value="5010"/>
    <arg name="frame_id" value="camera7"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
