    <arg name="udp_port" value="5013"/>
    <arg name="frame_id" value="camera10"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 11 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera11)">
    <arg name="namespace" value="camera11"/>
    <arg name="udp_port" value="5014"/>
    <arg name="frame_id" value="camera11"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>

  <!-- Camera 12 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera12)">
    <arg name="namespace" value="camera12"/>
    <arg name="udp_port" value="5015"/>
