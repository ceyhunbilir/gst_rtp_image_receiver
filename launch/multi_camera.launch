  </include>

  <!-- Camera 16 -->
  <include file="$(find rtp_receiver)/launch/rtp_image_receiver.launch" if="$(arg enable_camera16)">
    <arg name="namespace" value="camera16"/>
    <arg name="udp_port" value="5019"/>
    <arg name="frame_id" value="camera16"/>
    <arg name="width" value="1920"/>
    <arg name="height" value="1280"/>
    <arg name="jpeg_quality" value="90"/>
    <arg name="publish_raw" value="true"/>
    <arg name="publish_compressed" value="false"/>
  </include>
</launch>