<?xml version="1.0"?>
<launch>
  <!-- Launch arguments -->
  <arg name="udp_port" default="5004" doc="UDP port for RTP stream"/>
  <arg name="jpeg_quality" default="80" doc="JPEG compression quality (0-100)"/>
  <arg name="buffer_size" default="8388608" doc="Buffer size in bytes"/>
  <arg name="max_buffers" default="3" doc="Maximum number of buffers"/>
  <arg name="width" default="1920" doc="Video width in pixels"/>
  <arg name="height" default="1280" doc="Video height in pixels"/>
  <arg name="publish_raw" default="false" doc="Publish raw images"/>
  <arg name="publish_compressed" default="true" doc="Publish compressed images"/>
  <arg name="frame_id" default="camera" doc="Frame ID for published images"/>
  <arg name="namespace" default="rtp_receiver" doc="Namespace for the node"/>
  <arg name="camera_info_url" default="package://gst_rtp_image_receiver/config/camera_info.yaml" doc="URL for camera calibration file"/>

  <!-- RTP Image Receiver Node -->
  <group ns="$(arg namespace)">
    <node pkg="gst_rtp_image_receiver" type="rtp_image_receiver_node"
          name="rtp_image_receiver" output="screen">
      <param name="udp_port" value="$(arg udp_port)"/>
      <param name="jpeg_quality" value="$(arg jpeg_quality)"/>
      <param name="buffer_size" value="$(arg buffer_size)"/>
      <param name="max_buffers" value="$(arg max_buffers)"/>
      <param name="width" value="$(arg width)"/>
      <param name="height" value="$(arg height)"/>
      <param name="publish_raw" value="$(arg publish_raw)"/>
      <param name="publish_compressed" value="$(arg publish_compressed)"/>
      <param name="frame_id" value="$(arg frame_id)"/>
      <param name="camera_info_url" value="$(arg camera_info_url)"/>
    </node>
  </group>
</launch>